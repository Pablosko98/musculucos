{
  "name": "musculucos",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start -c",
    "android": "expo start -c --android",
    "ios": "expo start -c --ios",
    "web": "expo start -c --web",
    "clean": "rm -rf .expo node_modules",
    "android:dev": "rm -rf android/build android/app/build && npx expo run:android",
    "android:preview": "APP_VARIANT=preview npx expo prebuild --clean --platform android && rm -rf android/build android/app/build && APP_VARIANT=preview npx expo run:android --variant release",
    "android:switch-dev": "npx expo prebuild --platform android"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
